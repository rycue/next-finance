# Example environment variables for local development.
# Copy this to .env.local and replace values with your Neon/Postgres connection.

# Your Postgres connection string. Example formats:
# - Neon (recommended): postgres://<user>:<password>@<host>:5432/<db>?sslmode=require
# - Generic: postgres://user:password@hostname:5432/dbname

POSTGRES_URL=postgres://username:password@db-host:5432/database_name?sslmode=require

# Optional: NEXTAUTH configuration if you use next-auth in production
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=some-long-random-secret

# Add any other env vars your deployment uses here.