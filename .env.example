# Copy this file to `.env.local` and put your real database URL there.
#
# This app only needs one env var for the database:
# - `POSTGRES_URL`
#
# Replace the placeholder below with your real Neon/Postgres connection string.
# Example:
# POSTGRES_URL=postgresql://user:password@host:5432/database_name?sslmode=require

POSTGRES_URL=postgresql://username:password@db-host:5432/database_name?sslmode=requirev